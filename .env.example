# PROXVEL Admin Dashboard — variables de entorno (Vite)
# Copia este archivo como .env y ajusta los valores.

# URL base del backend PROXVEL (FastAPI). No incluir slash final.
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Etiqueta de versión mostrada en Configuración (opcional)
VITE_APP_VERSION=0.1.0-beta
